# =============================================================================
# DevDocs Assistant — Environment Variables
# =============================================================================
# Copy this file:  cp .env.example .env
# Never commit .env — it's in .gitignore
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=devdocs
POSTGRES_PASSWORD=devdocs_secret
POSTGRES_DB=devdocs
POSTGRES_PORT=5433

# --- pgAdmin ---
PGADMIN_EMAIL=admin@devdocs.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5051

# --- Redis ---
REDIS_PORT=6380

# --- Triton (uncomment in Phase 5) ---
# TRITON_HTTP_PORT=8000
# TRITON_GRPC_PORT=8001
# TRITON_METRICS_PORT=8002
